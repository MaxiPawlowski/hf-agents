{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hybrid-framework.local/schemas/runtime-event.schema.json",
  "title": "RuntimeEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "vendor",
    "type",
    "timestamp"
  ],
  "properties": {
    "vendor": {
      "type": "string",
      "enum": [
        "opencode",
        "claude",
        "runtime"
      ]
    },
    "sessionId": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  }
}
