{
  "name": "custom-agentic-framework",
  "version": "0.1.0",
  "private": true,
  "description": "Selective agentic framework with OAC-style delegation and modular skills.",
  "type": "module",
  "scripts": {
    "validate": "npm run validate:assets",
    "validate:registry": "node scripts/validation/validate-registry.mjs",
    "validate:deps": "node scripts/validation/check-dependencies.mjs",
    "validate:context-refs": "node scripts/validation/validate-context-refs.mjs",
    "validate:command-contracts": "node scripts/validation/lint-command-contracts.mjs",
    "validate:agent-contracts": "node scripts/validation/lint-agent-contracts.mjs",
    "validate:skill-contracts": "node scripts/validation/lint-skill-contracts.mjs",
    "validate:assets": "npm run validate:registry && npm run validate:deps && npm run validate:context-refs && npm run validate:command-contracts && npm run validate:agent-contracts && npm run validate:skill-contracts",
    "install:opencode": "node scripts/install/install-opencode-assets.mjs",
    "install:opencode:copy": "node scripts/install/install-opencode-assets.mjs --mode copy",
    "install:opencode:dry": "node scripts/install/install-opencode-assets.mjs --dry-run",
    "install:opencode:global": "node scripts/install/install-opencode-global.mjs",
    "install:opencode:global:dry": "node scripts/install/install-opencode-global.mjs --dry-run",
    "uninstall:opencode": "node scripts/install/uninstall-opencode-assets.mjs",
    "uninstall:opencode:dry": "node scripts/install/uninstall-opencode-assets.mjs --dry-run",
    "uninstall:opencode:global": "node scripts/install/uninstall-opencode-global.mjs",
    "uninstall:opencode:global:dry": "node scripts/install/uninstall-opencode-global.mjs --dry-run"
  }
}
