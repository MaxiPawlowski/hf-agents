{
  "name": "hybrid-framework",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "./dist/src/opencode/plugin.js",
  "exports": {
    ".": "./dist/src/opencode/plugin.js"
  },
  "files": [
    "README.md",
    ".claude/README.md",
    ".claude/settings.example.json",
    ".opencode/README.md",
    ".opencode/package.json",
    ".opencode/registry.json",
    "agents/hf-builder.md",
    "agents/hf-planner.md",
    "subagents/hf-coder.md",
    "subagents/hf-plan-reviewer.md",
    "subagents/hf-reviewer.md",
    "skills/*/SKILL.md",
    "schemas/*.json",
    "scripts/README.md",
    "scripts/lib/*.mjs",
    "scripts/postinstall.mjs",
    "scripts/sync-opencode-assets.mjs",
    "dist/src/**/*.js",
    "vault/templates/plan-context.md",
    "vault/templates/plan-decisions.md",
    "vault/templates/plan-discoveries.md",
    "vault/templates/plan-references.md",
    "vault/templates/shared-architecture.md",
    "vault/templates/shared-decisions.md",
    "vault/templates/shared-patterns.md"
  ],
  "bin": {
    "hf-runtime": "./dist/src/bin/hf-runtime.js",
    "hf-claude-hook": "./dist/src/bin/hf-claude-hook.js",
    "hf-mcp-server": "./dist/src/bin/hf-mcp-server.js",
    "hf-setup": "./dist/src/bin/hf-setup.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "postinstall": "node scripts/postinstall.mjs",
    "pack:check": "npm pack --dry-run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude tests/e2e/**/*.test.ts",
    "test:coverage": "vitest run --exclude tests/e2e/**/*.test.ts --coverage",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:e2e:claude": "vitest run --config vitest.config.e2e.ts --reporter=verbose tests/e2e/runtime-claude-e2e.test.ts",
    "test:e2e:vault-claude": "cross-env HF_RUN_SLOW=1 vitest run --config vitest.config.e2e.ts --reporter=verbose tests/e2e/vault-claude-e2e.test.ts",
    "test:bench": "cross-env HF_RUN_BENCHMARKS=1 vitest run --config vitest.config.e2e.ts",
    "test:slow": "cross-env HF_RUN_SLOW=1 vitest run --exclude tests/e2e/**/*.test.ts",
    "verify:e2e": "node scripts/verify-e2e.mjs",
    "lint": "npx oxlint src/ tests/ scripts/ && npx eslint src/ tests/ scripts/",
    "lint:fix": "npx oxlint --fix src/ tests/ scripts/ && npx eslint --fix src/ tests/ scripts/",
    "precommit": "npm run lint"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@img/sharp-linux-x64": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "oxlint": "^0.15.9",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.8"
  },
  "lint-staged": {
    "*.ts": [
      "npx oxlint",
      "npx eslint"
    ],
    "*.mjs": [
      "npx oxlint",
      "npx eslint"
    ]
  }
}
