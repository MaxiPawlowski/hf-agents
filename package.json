{
  "name": "hybrid-framework",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "./dist/src/opencode/plugin.js",
  "exports": {
    ".": "./dist/src/opencode/plugin.js"
  },
  "files": [
    "README.md",
    ".claude/README.md",
    ".claude/settings.example.json",
    ".opencode/README.md",
    ".opencode/package.json",
    ".opencode/registry.json",
    "agents/hf-builder.md",
    "agents/hf-planner.md",
    "subagents/hf-coder.md",
    "subagents/hf-plan-reviewer.md",
    "subagents/hf-reviewer.md",
    "skills/*/SKILL.md",
    "schemas/*.json",
    "scripts/README.md",
    "scripts/install-runtime.mjs",
    "scripts/install-claude.mjs",
    "scripts/install-opencode.mjs",
    "scripts/lib/*.mjs",
    "scripts/postinstall.mjs",
    "scripts/sync-opencode-assets.mjs",
    "dist/src/**/*.js",
    "vault/templates/plan-context.md",
    "vault/templates/plan-decisions.md",
    "vault/templates/plan-discoveries.md",
    "vault/templates/plan-references.md",
    "vault/templates/shared-architecture.md",
    "vault/templates/shared-decisions.md",
    "vault/templates/shared-patterns.md"
  ],
  "bin": {
    "hf-runtime": "./dist/src/bin/hf-runtime.js",
    "hf-claude-hook": "./dist/src/bin/hf-claude-hook.js",
    "hf-install": "./scripts/install-runtime.mjs",
    "hf-init": "./scripts/install-runtime.mjs",
    "hf-sync": "./scripts/install-runtime.mjs",
    "hf-uninstall": "./scripts/install-runtime.mjs",
    "hf-install-claude": "./scripts/install-claude.mjs",
    "hf-init-claude": "./scripts/install-claude.mjs",
    "hf-sync-claude": "./scripts/install-claude.mjs",
    "hf-uninstall-claude": "./scripts/install-claude.mjs",
    "hf-install-opencode": "./scripts/install-opencode.mjs",
    "hf-init-opencode": "./scripts/install-opencode.mjs",
    "hf-sync-opencode": "./scripts/install-opencode.mjs",
    "hf-uninstall-opencode": "./scripts/install-opencode.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "postinstall": "node scripts/postinstall.mjs",
    "hf:install": "node scripts/install-runtime.mjs install",
    "hf:init": "node scripts/install-runtime.mjs init",
    "hf:sync": "node scripts/install-runtime.mjs sync",
    "hf:uninstall": "node scripts/install-runtime.mjs uninstall",
    "hf:install:claude": "node scripts/install-claude.mjs install",
    "hf:init:claude": "node scripts/install-claude.mjs init",
    "hf:sync:claude": "node scripts/install-claude.mjs sync",
    "hf:uninstall:claude": "node scripts/install-claude.mjs uninstall",
    "hf:install:opencode": "node scripts/install-opencode.mjs install",
    "hf:init:opencode": "node scripts/install-opencode.mjs init",
    "hf:sync:opencode": "node scripts/install-opencode.mjs sync",
    "hf:uninstall:opencode": "node scripts/install-opencode.mjs uninstall",
    "pack:check": "npm pack --dry-run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude tests/e2e/**/*.test.ts",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:e2e:claude": "vitest run --config vitest.config.e2e.ts --reporter=verbose tests/e2e/runtime-claude-e2e.test.ts",
    "test:e2e:vault-claude": "cross-env HF_RUN_SLOW=1 vitest run --config vitest.config.e2e.ts --reporter=verbose tests/e2e/vault-claude-e2e.test.ts",
    "test:bench": "cross-env HF_RUN_BENCHMARKS=1 vitest run --config vitest.config.e2e.ts",
    "test:slow": "cross-env HF_RUN_SLOW=1 vitest run --exclude tests/e2e/**/*.test.ts",
    "verify:e2e": "node scripts/verify-e2e.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "cross-env": "^10.1.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
