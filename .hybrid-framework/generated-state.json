{
  "version": 1,
  "packageName": "hybrid-framework",
  "adapters": {
    "claude": {
      "commands": [
        "node \"$CLAUDE_PROJECT_DIR/dist/src/bin/hf-claude-hook.js\" SessionStart",
        "node \"$CLAUDE_PROJECT_DIR/dist/src/bin/hf-claude-hook.js\" UserPromptSubmit",
        "node \"$CLAUDE_PROJECT_DIR/dist/src/bin/hf-claude-hook.js\" PreToolUse",
        "node \"$CLAUDE_PROJECT_DIR/dist/src/bin/hf-claude-hook.js\" PreCompact",
        "node \"$CLAUDE_PROJECT_DIR/dist/src/bin/hf-claude-hook.js\" Stop",
        "node \"$CLAUDE_PROJECT_DIR/dist/src/bin/hf-claude-hook.js\" SubagentStart",
        "node \"$CLAUDE_PROJECT_DIR/dist/src/bin/hf-claude-hook.js\" SubagentStop"
      ],
      "settingsPath": ".claude/settings.local.json",
      "mcpConfigPath": ".mcp.json",
      "generatedPaths": [],
      "managedDirectories": []
    },
    "opencode": {
      "generatedPaths": [
        ".opencode/plugins/hybrid-runtime.js",
        ".opencode/registry.json",
        ".opencode/package.json",
        ".opencode/README.md",
        ".opencode/agents/hf-builder.md",
