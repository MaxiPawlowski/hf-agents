        ".opencode/agents/hf-plan-reviewer.md",
        ".opencode/agents/hf-planner.md",
        ".opencode/agents/hf-reviewer.md",
        ".opencode/skills/local-context/evals/evals.json",
        ".opencode/skills/local-context/REVIEW.md",
        ".opencode/skills/local-context/SKILL.md",
        ".opencode/skills/milestone-tracking/evals/evals.json",
        ".opencode/skills/milestone-tracking/REVIEW.md",
        ".opencode/skills/milestone-tracking/SKILL.md",
        ".opencode/skills/plan-synthesis/evals/evals.json",
        ".opencode/skills/plan-synthesis/REVIEW.md",
        ".opencode/skills/plan-synthesis/SKILL.md",
        ".opencode/skills/verification-before-completion/evals/evals.json",
        ".opencode/skills/verification-before-completion/REVIEW.md",
        ".opencode/skills/verification-before-completion/SKILL.md"
      ],
      "managedDirectories": [
        ".opencode/plugins",
        ".opencode/agents",
        ".opencode/skills"
      ]
    }
  }
}
