# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.
#
# Generate a token in SonarQube:
#   1. npm run sonar:start  (starts the Docker container)
#   2. Open http://localhost:9000, log in (admin / admin), change password
#   3. Administration > Projects > Create Project > Manually
#      key: hybrid-framework  |  name: Hybrid Framework
#   4. My Account > Security > Generate Tokens
#      name: hybrid-framework-local  |  type: Global Analysis Token
#   5. Paste the token below
SONAR_TOKEN=
