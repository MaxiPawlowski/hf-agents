{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [],
  "provider": {
    "lm-studio-custom": {
      "name": "LM Studio Custom",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "openai/gpt-oss-20b": {
          "name": "gpt-oss-20b"
        },
        "zai-org/glm-4.7-flash": {
          "name": "glm-4.7-flash"
        },
        "qwen/qwen3-vl-30b": {
          "name": "qwen3-vl-30b"
        }
      },
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    }
  },
   "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
    /*
      "chrome-devtools": {
        "type": "local",
        "command": ["npx", "-y", "--no-usage-statistics", "chrome-devtools-mcp@latest"],
        "enabled": true
      },
    */
  }
}